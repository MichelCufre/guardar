<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="false"
      internalLogLevel="Off"
      internalLogFile="c:\temp\internal-nlog-AspNetCore3.txt">

	<!-- enable asp.net core layout renderers -->
	<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
	</extensions>

	<variable name="baseDirectory" value="C:/WIS/"/>

	<!-- the targets to write to -->
	<targets>

		<target xsi:type="File" name="errorFile" fileName="${baseDirectory}/NLog/MultidataCodeConverter/Error/${shortdate}/user_${mdlc:UserId}.log"
		  maxArchiveDays = "45"
		  archiveAboveSize = "100000"
		  layout="${longdate} ${uppercase:${level}}${newline}
            Aplicacion: ${mdlc:Application}${newline}
            Exception Type: ${exception:format=Type}${newline}
            Exception Message: ${exception:format=Message}${newline}
            Stack Trace: ${exception:format=tostring}${newline}
            Additional Info: ${message}" />

		<target xsi:type="File" name="debugFile" fileName="${baseDirectory}/NLog/MultidataCodeConverter/Debug/${shortdate}/user_${mdlc:UserId}.log"
		  maxArchiveDays = "45"
		  archiveAboveSize = "100000"
		  layout="${longdate} ${uppercase:${level}}${newline}
            Aplicacion: ${mdlc:Application}
            Additional Info: ${message}" />

	</targets>

	<!-- rules to map from logger name to target -->
	<rules>
		<logger name="*" minlevel="Warn" writeTo="errorFile" />
		<logger name="*" minlevel="Trace" maxlevel="Info" writeTo="debugFile" />

		<!--Skip non-critical Microsoft logs and so log only own logs-->
		<logger name="Microsoft.*" maxLevel="Info" final="true" />

	</rules>
</nlog>